{
    "name": "graftechnology/pdfshift",
    "description": "Easily implement PDFShift (https://pdfshift.io/) into Craft CMS.",
    "type": "craft-plugin",
    "keywords": [
        "craft",
        "cms",
        "craftcms",
        "craft-plugin",
        "pdfshift",
        "pdf"
    ],
    "support": {
        "docs": "https://github.com/jacobgraf/pdfshift/blob/master/README.md",
        "issues": "https://github.com/jacobgraf/pdfshift/issues"
    },
    "license": "proprietary",
    "authors": [
        {
            "name": "Graf Technology, LLC",
            "homepage": "https://graftechnology.com/"
        }
    ],
    "require": {
        "php": "^8.0.2",
        "craftcms/cms": "^4.0|^5.0"
    },
    "autoload": {
        "psr-4": {
            "graftechnology\\pdfshift\\": "src/"
        }
    },
    "extra": {
        "name": "PDFShift",
        "handle": "pdfshift",
        "documentationUrl": "https://github.com/jacobgraf/pdfshift/blob/master/README.md",
        "changelogUrl": "https://raw.githubusercontent.com/jacobgraf/pdfshift/master/CHANGELOG.md",
        "class": "graftechnology\\pdfshift\\PdfShift"
    },
    "config": {
        "allow-plugins": {
            "yiisoft/yii2-composer": true,
            "craftcms/plugin-installer": true
        },
        "sort-packages": true
    }
}
